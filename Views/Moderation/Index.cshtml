@model AdminDashboardViewModel

@{
    ViewData["Title"] = "Moderation";
}

<section class="content-shell">
    <div class="section-heading">
        <h1 class="mb-0">Moderation</h1>
        <div class="d-flex gap-2">
            <a class="btn btn-primary" asp-controller="Beneficiaries" asp-action="Create">Add beneficiary</a>
            <a class="btn btn-outline-dark" asp-controller="Beneficiaries" asp-action="Index">Beneficiaries</a>
        </div>
    </div>

    <div class="row g-4 mt-1">
        <div class="col-md-6 col-xl-3">
            <article class="content-card h-100">
                <span class="impact-label">Users</span>
                <strong class="dashboard-number">@Model.TotalUsers</strong>
            </article>
        </div>
        <div class="col-md-6 col-xl-3">
            <article class="content-card h-100">
                <span class="impact-label">Beneficiaries</span>
                <strong class="dashboard-number">@Model.TotalBeneficiaries</strong>
            </article>
        </div>
        <div class="col-md-6 col-xl-3">
            <article class="content-card h-100">
                <span class="impact-label">Campaigns</span>
                <strong class="dashboard-number">@Model.TotalCampaigns</strong>
            </article>
        </div>
        <div class="col-md-6 col-xl-3">
            <article class="content-card h-100">
                <span class="impact-label">Raised total</span>
                <strong class="dashboard-number">@CurrencyFormatter.Euro(Model.TotalRaised)</strong>
            </article>
        </div>
    </div>
</section>

<section class="content-shell">
    <div class="section-heading">
        <h2 class="h3 mb-0">Beneficiaries to review</h2>
    </div>

    @if (!Model.BeneficiaryReviewItems.Any())
    {
        <article class="content-card mt-4">
            <p class="mb-0">There are no beneficiaries to review.</p>
        </article>
    }
    else
    {
        <div class="row g-4 mt-1">
            @foreach (var beneficiary in Model.BeneficiaryReviewItems)
            {
                <div class="col-lg-6">
                    <article class="content-card h-100">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <span class="badge rounded-pill @(beneficiary.IsVerified ? "text-bg-success" : "text-bg-secondary")">
                                @(beneficiary.IsVerified ? "Verified" : "Unverified")
                            </span>
                            <span class="small text-secondary">@beneficiary.Kind</span>
                        </div>
                        <h2 class="h4">@beneficiary.FullName</h2>
                        <p class="text-secondary">@beneficiary.Story</p>
                        <dl class="row small mb-4">
                            <dt class="col-sm-4">About</dt>
                            <dd class="col-sm-8">@beneficiary.FocusArea</dd>
                            <dt class="col-sm-4">City</dt>
                            <dd class="col-sm-8">@beneficiary.City</dd>
                            <dt class="col-sm-4">Manager</dt>
                            <dd class="col-sm-8">@(beneficiary.ManagerUser?.Email ?? "-")</dd>
                        </dl>
                        <div class="d-flex gap-2 flex-wrap">
                            <a class="btn btn-outline-dark" asp-controller="Beneficiaries" asp-action="Details" asp-route-id="@beneficiary.Id">View</a>
                            <a class="btn btn-outline-dark" asp-controller="Beneficiaries" asp-action="Edit" asp-route-id="@beneficiary.Id">Edit</a>
                            <a class="btn btn-primary" asp-controller="Beneficiaries" asp-action="Verify" asp-route-id="@beneficiary.Id" asp-route-returnUrl="@Url.Action("Index", "Moderation")">
                                @(beneficiary.IsVerified ? "Set unverified" : "Verify beneficiary")
                            </a>
                        </div>
                    </article>
                </div>
            }
        </div>
    }
</section>

<section class="content-shell">
    <div class="section-heading">
        <h2 class="h3 mb-0">Deletion requests</h2>
    </div>

    @if (!Model.DeletionRequestCampaigns.Any())
    {
        <article class="content-card mt-4">
            <p class="mb-0">There are no deletion requests right now.</p>
        </article>
    }
    else
    {
        <div class="row g-4 mt-1">
            @foreach (var campaign in Model.DeletionRequestCampaigns)
            {
                <div class="col-lg-6">
                    <article class="content-card h-100">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <span class="badge rounded-pill text-bg-danger">Deletion requested</span>
                            <span class="small text-secondary">Owner @campaign.Owner?.FullName</span>
                        </div>
                        <h2 class="h4">@campaign.Title</h2>
                        <p class="text-secondary">@campaign.Summary</p>
                        <div class="d-flex gap-2 flex-wrap">
                            <a class="btn btn-outline-dark" asp-controller="Campaigns" asp-action="Details" asp-route-id="@campaign.Id">View</a>
                            <form asp-action="ToggleCampaignHidden" method="post">
                                <input type="hidden" name="id" value="@campaign.Id" />
                                <button type="submit" class="btn btn-outline-dark">
                                    @(campaign.IsHidden ? "Show campaign" : "Hide campaign")
                                </button>
                            </form>
                            <form asp-action="ApproveDeletion" method="post">
                                <input type="hidden" name="id" value="@campaign.Id" />
                                <button type="submit" class="btn btn-danger">Approve deletion</button>
                            </form>
                        </div>
                    </article>
                </div>
            }
        </div>
    }
</section>

<section class="content-shell">
    <div class="section-heading">
        <h2 class="h3 mb-0">Pending campaigns</h2>
    </div>

    @if (!Model.PendingApprovalCampaigns.Any())
    {
        <article class="content-card mt-4">
            <p class="mb-0">There are no campaigns waiting for approval.</p>
        </article>
    }
    else
    {
        <div class="row g-4 mt-1">
            @foreach (var campaign in Model.PendingApprovalCampaigns)
            {
                <div class="col-lg-6">
                    <article class="content-card h-100">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <span class="badge rounded-pill text-bg-secondary">Pending approval</span>
                            <span class="small text-secondary">Submitted @DateFormatter.EnglishShort(campaign.CreatedOn)</span>
                        </div>
                        <h2 class="h4">@campaign.Title</h2>
                        <p class="text-secondary">@campaign.Summary</p>
                        <dl class="row small mb-4">
                            <dt class="col-sm-4">Owner</dt>
                            <dd class="col-sm-8">@campaign.Owner?.FullName</dd>
                            <dt class="col-sm-4">Beneficiary</dt>
                            <dd class="col-sm-8">@campaign.Beneficiary?.FullName</dd>
                            <dt class="col-sm-4">Goal</dt>
                            <dd class="col-sm-8">@CurrencyFormatter.Euro(campaign.GoalAmount)</dd>
                        </dl>
                        <div class="d-flex gap-2">
                            <a class="btn btn-outline-dark" asp-controller="Campaigns" asp-action="Details" asp-route-id="@campaign.Id">View</a>
                            <a class="btn btn-primary" asp-controller="Campaigns" asp-action="Approve" asp-route-id="@campaign.Id" asp-route-returnUrl="@Url.Action("Index", "Moderation")">Approve campaign</a>
                        </div>
                    </article>
                </div>
            }
        </div>
    }
</section>

<section class="content-shell">
    <div class="section-heading">
        <h2 class="h3 mb-0">Approved campaigns</h2>
    </div>

    <div class="row g-4 mt-1">
        @foreach (var campaign in Model.ApprovedCampaigns)
        {
            <div class="col-lg-6">
                <article class="content-card h-100">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <span class="badge rounded-pill @(campaign.IsFeatured ? "text-bg-warning" : "text-bg-light border")">
                            @(campaign.IsFeatured ? "Featured" : "Standard")
                        </span>
                        <span class="small text-secondary">Ends @DateFormatter.EnglishShort(campaign.EndDate)</span>
                    </div>
                    <h3 class="h4">@campaign.Title</h3>
                    <p class="text-secondary">@campaign.Summary</p>
                    <div class="d-flex gap-2">
                        <a class="btn btn-outline-dark" asp-controller="Campaigns" asp-action="Edit" asp-route-id="@campaign.Id">Edit</a>
                        <form asp-action="ToggleFeatured" method="post">
                            <input type="hidden" name="id" value="@campaign.Id" />
                            <button type="submit" class="btn btn-primary">
                                @(campaign.IsFeatured ? "Remove featured" : "Make featured")
                            </button>
                        </form>
                    </div>
                </article>
            </div>
        }
    </div>
</section>

<section class="content-shell">
    <div class="section-heading">
        <h2 class="h3 mb-0">Latest donations</h2>
    </div>

    <div class="table-responsive mt-3">
        <table class="table admin-table align-middle">
            <thead>
                <tr>
                    <th>Donor</th>
                    <th>Campaign</th>
                    <th>Beneficiary</th>
                    <th>Amount</th>
                    <th>Frequency</th>
                    <th>Status</th>
                    <th>Date</th>
                    <th>Note</th>
                    <th>Visibility</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var donation in Model.LatestDonations)
                {
                    <tr>
                        <td>@donation.DonorName</td>
                        <td>@donation.FundingCampaign?.Title</td>
                        <td>@donation.FundingCampaign?.Beneficiary?.FullName</td>
                        <td>@CurrencyFormatter.Euro(donation.Amount)</td>
                        <td>@donation.Frequency</td>
                        <td>@donation.Status</td>
                        <td>@DateFormatter.EnglishShort(donation.DonatedOn)</td>
                        <td>
                            @if (string.IsNullOrWhiteSpace(donation.Note))
                            {
                                <span>-</span>
                            }
                            else if (donation.IsCommentHidden)
                            {
                                <span>Hidden publicly: @donation.Note</span>
                            }
                            else
                            {
                                @donation.Note
                            }
                        </td>
                        <td>
                            <form asp-action="ToggleDonationVisibility" method="post">
                                <input type="hidden" name="id" value="@donation.Id" />
                                <button type="submit" class="btn btn-sm @(donation.IsDonationHidden ? "btn-outline-dark" : "btn-outline-danger")">
                                    @(donation.IsDonationHidden ? "Show donation" : "Hide donation")
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>

<section class="content-shell">
    <div class="section-heading">
        <h2 class="h3 mb-0">Users</h2>
    </div>

    <form method="get" class="content-card mt-3">
        <div class="row g-3 align-items-end">
            <div class="col-md-8">
                <label class="form-label" for="userSearch">Search</label>
                <input class="form-control" id="userSearch" name="userSearch" value="@ViewBag.UserSearch" placeholder="Search users" />
            </div>
            <div class="col-md-4">
                <label class="form-label" for="userRole">Role</label>
                <select class="form-select" id="userRole" name="userRole">
                    <option value="all" selected="@((ViewBag.UserRole as string ?? "all") == "all")">All</option>
                    <option value="admins" selected="@((ViewBag.UserRole as string ?? "all") == "admins")">Admins</option>
                    <option value="users" selected="@((ViewBag.UserRole as string ?? "all") == "users")">Users</option>
                </select>
            </div>
        </div>
        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary">Apply</button>
            <a class="btn btn-outline-dark" asp-action="Index">Clear</a>
        </div>
    </form>

    <div class="table-responsive mt-3">
        <table class="table admin-table align-middle">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Created campaigns</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model.Users)
                {
                    <tr>
                        <td>@user.FullName</td>
                        <td>@user.Email</td>
                        <td>@(string.IsNullOrWhiteSpace(user.PhoneNumber) ? "-" : user.PhoneNumber)</td>
                        <td>@user.CreatedCampaigns.Count</td>
                        <td>
                            <a class="btn btn-sm btn-outline-dark" asp-action="UserDetails" asp-route-id="@user.Id">Details</a>
                            <a class="btn btn-sm btn-outline-dark" asp-action="EditUser" asp-route-id="@user.Id">Edit user</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
