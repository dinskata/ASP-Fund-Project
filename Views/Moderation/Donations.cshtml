@model AdminDashboardViewModel

@{
    ViewData["Title"] = "Moderation donations";
    var currentSearch = ViewBag.Search as string;
    var currentStatus = ViewBag.Status as string ?? "all";
}

<section class="content-shell">
    <div class="section-heading">
        <h1 class="mb-0">Donations</h1>
    </div>
    <partial name="_ModerationNav" />

    <form method="get" class="content-card mt-3">
        <div class="row g-3 align-items-end">
            <div class="col-md-8">
                <label class="form-label" for="search">Search</label>
                <input class="form-control" id="search" name="search" value="@currentSearch" placeholder="Search donations" />
            </div>
            <div class="col-md-4">
                <label class="form-label" for="status">Filter</label>
                <select class="form-select" id="status" name="status">
                    <option value="all" selected="@(currentStatus == "all")">All</option>
                    <option value="active" selected="@(currentStatus == "active")">Active recurring</option>
                    <option value="successful" selected="@(currentStatus == "successful")">Successful</option>
                    <option value="recurring" selected="@(currentStatus == "recurring")">Recurring</option>
                    <option value="weekly" selected="@(currentStatus == "weekly")">Weekly</option>
                    <option value="monthly" selected="@(currentStatus == "monthly")">Monthly</option>
                    <option value="hidden" selected="@(currentStatus == "hidden")">Hidden</option>
                    <option value="visible" selected="@(currentStatus == "visible")">Visible</option>
                </select>
            </div>
        </div>
        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary">Apply</button>
            <a class="btn btn-outline-dark" asp-action="Donations">Clear</a>
        </div>
    </form>

    <div class="table-responsive mt-3">
        <table class="table admin-table align-middle">
            <thead>
                <tr>
                    <th>Donor</th>
                    <th>Campaign</th>
                    <th>Beneficiary</th>
                    <th>Amount</th>
                    <th>Frequency</th>
                    <th>Next payment</th>
                    <th>Status</th>
                    <th>Date</th>
                    <th>Note</th>
                    <th>Visibility</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var donation in Model.LatestDonations)
                {
                    var nextPaymentDate = donation.Status == ContributionStatus.Successful
                        ? donation.Frequency switch
                        {
                            ContributionFrequency.Weekly => donation.DonatedOn.AddDays(7),
                            ContributionFrequency.Monthly => donation.DonatedOn.AddMonths(1),
                            _ => (DateTime?)null
                        }
                        : null;

                    <tr>
                        <td>@donation.DonorName</td>
                        <td>@donation.FundingCampaign?.Title</td>
                        <td>@donation.FundingCampaign?.Beneficiary?.FullName</td>
                        <td>@CurrencyFormatter.Euro(donation.Amount)</td>
                        <td>@donation.Frequency</td>
                        <td>@(nextPaymentDate.HasValue ? DateFormatter.EnglishShort(nextPaymentDate.Value) : "-")</td>
                        <td>@donation.Status</td>
                        <td>@DateFormatter.EnglishShort(donation.DonatedOn)</td>
                        <td>
                            @if (string.IsNullOrWhiteSpace(donation.Note))
                            {
                                <span>-</span>
                            }
                            else if (donation.IsCommentHidden)
                            {
                                <span>Hidden publicly: @donation.Note</span>
                            }
                            else
                            {
                                @donation.Note
                            }
                        </td>
                        <td>
                            <form asp-action="ToggleDonationVisibility" method="post">
                                <input type="hidden" name="id" value="@donation.Id" />
                                <button type="submit" class="btn btn-sm @(donation.IsDonationHidden ? "btn-outline-dark" : "btn-outline-danger")">
                                    @(donation.IsDonationHidden ? "Show donation" : "Hide donation")
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
