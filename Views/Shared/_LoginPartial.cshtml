@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@functions {
    private static string MaskEmail(string? email)
    {
        if (string.IsNullOrWhiteSpace(email) || !email.Contains('@'))
        {
            return string.Empty;
        }

        var parts = email.Split('@', 2);
        var local = parts[0];
        return $"{local[0]}***{local[^1]}@{parts[1]}";
    }
}

<ul class="navbar-nav ms-lg-3 align-items-lg-center gap-lg-2">
@if (SignInManager.IsSignedIn(User))
{
    @if (User.IsInRole(ApplicationRoles.Administrator))
    {
        <li class="nav-item">
            <a class="nav-link" asp-controller="Moderation" asp-action="Index">Moderation</a>
        </li>
    }
    <li class="nav-item">
        <div class="dropdown">
            <button class="account-chip dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                @MaskEmail(UserManager.GetUserName(User))
            </button>
            <ul class="dropdown-menu dropdown-menu-end profile-dropdown">
                <li><a class="dropdown-item" asp-controller="Profile" asp-action="Settings">Profile settings</a></li>
                <li><a class="dropdown-item" asp-controller="Profile" asp-action="Organizations">Organizations</a></li>
                <li><a class="dropdown-item" asp-controller="Profile" asp-action="Causes">Causes</a></li>
                <li><a class="dropdown-item" asp-controller="Profile" asp-action="MyDonations">My donations</a></li>
                <li><a class="dropdown-item" asp-controller="Profile" asp-action="Financial">Financial</a></li>
                <li><hr class="dropdown-divider" /></li>
                <li>
                    <form class="px-2 pb-2" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                        <button type="submit" class="dropdown-item">Logout</button>
                    </form>
                </li>
            </ul>
        </div>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link" asp-area="Identity" asp-page="/Account/Login">Login</a>
    </li>
    <li class="nav-item">
        <a class="btn btn-primary btn-sm" asp-area="Identity" asp-page="/Account/Register">Register</a>
    </li>
}
</ul>
