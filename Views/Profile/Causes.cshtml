@model IReadOnlyCollection<FundingCampaign>

@{
    ViewData["Title"] = "My causes";
    var isAdminProfile = (bool?)ViewBag.IsAdminProfile == true;
    var currentSearch = ViewBag.Search as string;
    var currentStatus = ViewBag.Status as string ?? "all";
    var currentCategory = ViewBag.Category as CampaignCategory?;
}

<section class="content-shell narrow-shell">
    <div class="section-heading mb-3">
        <h1 class="mb-0">My causes</h1>
        <a class="btn btn-outline-dark" asp-controller="Campaigns" asp-action="Create">Add cause</a>
    </div>
    <partial name="_ProfileNav" />

    @if (isAdminProfile)
    {
        <form method="get" class="content-card mb-4">
            <div class="row g-3 align-items-end">
                <div class="col-md-5">
                    <label class="form-label" for="search">Search</label>
                    <input class="form-control" id="search" name="search" value="@currentSearch" placeholder="Search causes" />
                </div>
                <div class="col-md-4">
                    <label class="form-label" for="category">Category</label>
                    <select class="form-select" id="category" name="category">
                        <option value="">All categories</option>
                        @foreach (var item in Html.GetEnumSelectList<CampaignCategory>())
                        {
                            if (item.Value == ((int?)currentCategory)?.ToString())
                            {
                                <option value="@item.Value" selected>@item.Text</option>
                            }
                            else
                            {
                                <option value="@item.Value">@item.Text</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label" for="status">Status</label>
                    <select class="form-select" id="status" name="status">
                        <option value="all" selected="@(currentStatus == "all")">All</option>
                        <option value="approved" selected="@(currentStatus == "approved")">Approved</option>
                        <option value="pending" selected="@(currentStatus == "pending")">Pending</option>
                        <option value="featured" selected="@(currentStatus == "featured")">Featured</option>
                    </select>
                </div>
            </div>
            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">Apply</button>
                <a class="btn btn-outline-dark" asp-action="Causes">Clear</a>
            </div>
        </form>
    }

    <section class="content-card">
        @if (Model.Any())
        {
            <div class="list-group list-group-flush">
                @foreach (var cause in Model)
                {
                    <div class="list-group-item px-0 d-flex justify-content-between align-items-center">
                        <div>
                            <div class="fw-semibold">@cause.Title</div>
                            <div class="small text-secondary">@cause.Beneficiary?.FullName</div>
                            <div class="small text-secondary">
                                @CurrencyFormatter.Euro(cause.CurrentAmount) of @CurrencyFormatter.Euro(cause.GoalAmount)
                                | @(cause.IsApproved ? "Approved" : "Waiting for approval")
                            </div>
                        </div>
                        <div class="d-flex gap-2">
                            <a class="btn btn-sm btn-outline-dark" asp-controller="Campaigns" asp-action="Details" asp-route-id="@cause.Id" asp-route-returnUrl="@Url.Action("Causes", "Profile")">View</a>
                            <a class="btn btn-sm btn-outline-dark" asp-controller="Campaigns" asp-action="Edit" asp-route-id="@cause.Id" asp-route-returnUrl="@Url.Action("Causes", "Profile")">Edit</a>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <p class="mb-0">You have not created any causes yet.</p>
        }
    </section>
</section>
