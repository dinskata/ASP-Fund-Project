@model CampaignIndexViewModel

@{
    ViewData["Title"] = "Campaigns";
}

<section class="content-shell">
    <div class="section-heading">
        <h1 class="mb-0">Campaigns</h1>
        @if (User.Identity?.IsAuthenticated ?? false)
        {
            <a class="btn btn-primary" asp-action="Create">Create new campaign</a>
        }
        else
        {
            <a class="btn btn-primary" asp-area="Identity" asp-page="/Account/Register">Register to create</a>
        }
    </div>

    <form method="get" class="content-card mt-4">
        <div class="row g-3 align-items-end">
            <div class="col-lg-5">
                <label class="form-label" for="searchTerm">Search</label>
                <input class="form-control" id="searchTerm" name="searchTerm" value="@Model.SearchTerm" placeholder="Title, organizer, beneficiary" />
            </div>
            <div class="col-lg-3">
                <label class="form-label" for="category">Category</label>
                <select class="form-select" id="category" name="category" asp-for="Category" asp-items="Html.GetEnumSelectList<CampaignCategory>()">
                    <option value="">All categories</option>
                </select>
            </div>
            <div class="col-lg-3">
                <label class="form-label" for="status">Filter</label>
                <select class="form-select" id="status" name="status">
                    @if (Model.Status == "approved")
                    {
                        <option value="all">All campaigns</option>
                        <option value="approved" selected>Approved</option>
                        <option value="featured">Featured</option>
                        <option value="pending">Pending</option>
                    }
                    else if (Model.Status == "featured")
                    {
                        <option value="all">All campaigns</option>
                        <option value="approved">Approved</option>
                        <option value="featured" selected>Featured</option>
                        <option value="pending">Pending</option>
                    }
                    else if (Model.Status == "pending")
                    {
                        <option value="all">All campaigns</option>
                        <option value="approved">Approved</option>
                        <option value="featured">Featured</option>
                        <option value="pending" selected>Pending</option>
                    }
                    else if (Model.Status == "mine")
                    {
                        <option value="all">All campaigns</option>
                        <option value="approved">Approved</option>
                        <option value="featured">Featured</option>
                        <option value="pending">Pending</option>
                    }
                    else
                    {
                        <option value="all" selected>All campaigns</option>
                        <option value="approved">Approved</option>
                        <option value="featured">Featured</option>
                        <option value="pending">Pending</option>
                    }
                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        if (Model.Status == "mine")
                        {
                            <option value="mine" selected>My campaigns</option>
                        }
                        else
                        {
                            <option value="mine">My campaigns</option>
                        }
                    }
                </select>
            </div>
            <div class="col-lg-1 d-grid">
                <button type="submit" class="btn btn-dark">Go</button>
            </div>
        </div>
    </form>

    @if (Model.Campaigns.Any())
    {
        <div class="row g-4 mt-1">
            @foreach (var campaign in Model.Campaigns)
            {
                var progress = campaign.GoalAmount == 0 ? 0 : Math.Min(100, (campaign.CurrentAmount / campaign.GoalAmount) * 100);

                <div class="col-lg-6">
                    <article class="content-card h-100 @(campaign.IsApproved ? string.Empty : "pending-card")">
                        <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                            <div>
                                <span class="badge rounded-pill text-bg-light border">@campaign.Category</span>
                                @if (campaign.IsFeatured)
                                {
                                    <span class="badge rounded-pill text-bg-warning ms-2">Featured</span>
                                }
                            @if (!campaign.IsApproved)
                            {
                                <span class="badge rounded-pill text-bg-secondary ms-2">Pending approval</span>
                            }
                            @if (campaign.IsHidden)
                            {
                                <span class="badge rounded-pill text-bg-dark ms-2">Hidden</span>
                            }
                            @if (campaign.IsDeletionRequested)
                            {
                                <span class="badge rounded-pill text-bg-danger ms-2">Deletion requested</span>
                            }
                            </div>
                            <span class="small text-muted">Ends @DateFormatter.EnglishShort(campaign.EndDate)</span>
                        </div>
                        <h2 class="h4">@campaign.Title</h2>
                        <p class="text-secondary">@campaign.Summary</p>
                        <dl class="row small mb-3">
                            <dt class="col-sm-4">Organizer</dt>
                            <dd class="col-sm-8">@campaign.OrganizerName</dd>
                            <dt class="col-sm-4">Beneficiary</dt>
                            <dd class="col-sm-8">@campaign.Beneficiary?.FullName</dd>
                            <dt class="col-sm-4">Owner</dt>
                            <dd class="col-sm-8">@campaign.Owner?.FullName</dd>
                        </dl>
                        <div class="progress mb-2" role="progressbar" aria-label="Campaign progress" aria-valuenow="@progress" aria-valuemin="0" aria-valuemax="100">
                            <div class="progress-bar" style="width: @CurrencyFormatter.Percent(progress)"></div>
                        </div>
                        <div class="d-flex justify-content-between small text-secondary mb-3">
                            <span>@CurrencyFormatter.Euro(campaign.CurrentAmount) raised</span>
                            <span>@CurrencyFormatter.Euro(campaign.GoalAmount) goal</span>
                        </div>
                        <div class="d-flex flex-wrap gap-2">
                            <a class="btn btn-dark btn-sm" asp-action="Details" asp-route-id="@campaign.Id">View</a>
                            @if (campaign.IsApproved)
                            {
                                <a class="btn btn-primary btn-sm" asp-action="Donate" asp-route-id="@campaign.Id">Donate</a>
                            }
                            @if (User.IsInRole(ApplicationRoles.Administrator))
                            {
                                <a class="btn btn-outline-dark btn-sm" asp-action="Edit" asp-route-id="@campaign.Id">Edit</a>
                            }
                            else if (campaign.OwnerId == User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value)
                            {
                                <a class="btn btn-outline-dark btn-sm" asp-action="Edit" asp-route-id="@campaign.Id">Edit</a>
                                <a class="btn btn-outline-danger btn-sm" asp-action="Delete" asp-route-id="@campaign.Id">Delete</a>
                            }
                        </div>
                    </article>
                </div>
            }
        </div>
    }
    else
    {
        <div class="content-card mt-4">
            <p class="mb-0">No campaigns found for the selected criteria.</p>
        </div>
    }
</section>
