@model DonateViewModel
@using System.Globalization

@{
    ViewData["Title"] = "Donate";
}

<section class="content-shell narrow-shell">
    <span class="eyebrow">Donate</span>
    <h1 class="mb-3">Support @Model.CampaignTitle</h1>

    <form asp-action="Donate" method="post" class="content-card" id="donationForm">
        <input asp-for="FundingCampaignId" type="hidden" />
        <input asp-for="CampaignTitle" type="hidden" />
        <input asp-for="BeneficiaryName" type="hidden" />
        <input asp-for="BankAccountName" type="hidden" />
        <input asp-for="BankName" type="hidden" />
        <input asp-for="Iban" type="hidden" />
        <input asp-for="Bic" type="hidden" />
        <input asp-for="PaymentMethod" type="hidden" id="paymentMethodField" value="Card" />
        <input asp-for="CardTestOutcome" type="hidden" id="cardTestOutcomeField" />

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="DonorName" class="form-label"></label>
                <input asp-for="DonorName" class="form-control" />
                <span asp-validation-for="DonorName" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Amount" class="form-label"></label>
                <input asp-for="Amount" class="form-control" type="text" inputmode="decimal" data-decimal-field value="@Model.Amount.ToString("0.00", CultureInfo.InvariantCulture)" />
                <span asp-validation-for="Amount" class="text-danger"></span>
            </div>
            <div class="col-12">
                <div class="form-check">
                    <input asp-for="IsAnonymous" class="form-check-input" />
                    <label asp-for="IsAnonymous" class="form-check-label"></label>
                </div>
            </div>
            <div class="col-12">
                <div class="form-check">
                    <input asp-for="IsHiddenDonation" class="form-check-input" />
                    <label asp-for="IsHiddenDonation" class="form-check-label"></label>
                </div>
                <div class="form-text">Only the organizer and admin can see hidden donations.</div>
            </div>
            <div class="col-12">
                <label asp-for="Frequency" class="form-label"></label>
                <select asp-for="Frequency" asp-items="Html.GetEnumSelectList<ContributionFrequency>()" class="form-select"></select>
            </div>
            <div class="col-12">
                <label asp-for="Note" class="form-label"></label>
                <textarea asp-for="Note" rows="4" class="form-control"></textarea>
                <span asp-validation-for="Note" class="text-danger"></span>
            </div>
        </div>

        <div class="d-flex flex-wrap gap-2 mt-4">
            <button type="button" class="btn btn-primary" id="cardDonationButton">Card payment</button>
            <a class="btn btn-outline-dark" asp-action="Details" asp-route-id="@Model.FundingCampaignId">Back</a>
        </div>
    </form>
</section>

<div class="modal fade" id="cardPaymentModal" tabindex="-1" aria-labelledby="cardPaymentModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content payment-modal">
            <div class="modal-header border-0 pb-0">
                <div>
                    <span class="eyebrow">Test card checkout</span>
                    <h2 class="modal-title h4 mb-0" id="cardPaymentModalLabel">Card payment</h2>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body pt-3">
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label">Card number</label>
                        <input class="form-control" value="4242 4242 4242 4242" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Expiry</label>
                        <input class="form-control" value="12/29" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">CVC</label>
                        <input class="form-control" value="123" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Cardholder name</label>
                        <input class="form-control" value="@(string.IsNullOrWhiteSpace(Model.DonorName) ? "Anonymous donor" : Model.DonorName)" />
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-outline-dark" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-outline-danger" data-card-outcome="unsuccessful">Unsuccessful donation</button>
                <button type="button" class="btn btn-primary" data-card-outcome="success">Successful donation</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const donationForm = document.getElementById('donationForm');
            const cardDonationButton = document.getElementById('cardDonationButton');
            const cardOutcomeField = document.getElementById('cardTestOutcomeField');
            const modalElement = document.getElementById('cardPaymentModal');
            const cardModal = new bootstrap.Modal(modalElement);

            cardDonationButton.addEventListener('click', () => {
                cardModal.show();
            });

            modalElement.querySelectorAll('[data-card-outcome]').forEach((button) => {
                button.addEventListener('click', () => {
                    cardOutcomeField.value = button.getAttribute('data-card-outcome');
                    donationForm.submit();
                });
            });
        })();
    </script>
}
